# Supabase project URL (Settings -> API -> Project URL)
SUPABASE_URL=

# Supabase service role key (Settings -> API -> service_role secret)
# Required because the scraper upserts into master_equipment, bypassing RLS.
# Never expose this key client-side or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase browser credentials (Settings -> API). The anon key is safe to
# expose client-side — access is governed by RLS policies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Symmetric key for encrypting proxy bid ceilings at rest (pgcrypto).
# Generate with: openssl rand -base64 32
# NEVER rotate while an auction is open — stored ceilings become unreadable.
BID_ENCRYPTION_KEY=

# Loops.so API key for transactional email (outbid notifications).
# Optional: when absent, outbid events log to console instead of sending.
LOOPS_API_KEY=

# Stripe — TEST MODE until launch. Prefer a restricted key (rk_test_...)
# over the full secret key. No account? npm i -g @stripe/cli && stripe
# sandbox create generates working sandbox keys.
STRIPE_SECRET_KEY=
# From the webhook endpoint config (Dashboard -> Developers -> Webhooks),
# or `stripe listen` output during local development.
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public site origin used in Stripe redirect URLs (checkout success/cancel,
# onboarding return). Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=

# Shared secret protecting cron endpoints (auction close sweep).
# Set the same value in Vercel project env — Vercel sends it as
# "Authorization: Bearer <CRON_SECRET>" on cron invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional — restrict a scrape run to one manufacturer slug and/or cap the
# number of products processed. Used for the dry run before a full crawl.
# SCRAPE_MANUFACTURER_FILTER=american-audio
# SCRAPE_LIMIT=20
